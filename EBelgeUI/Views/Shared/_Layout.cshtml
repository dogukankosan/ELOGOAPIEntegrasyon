@{
    var username = Context.Session.GetString("Username") ?? "Kullanıcı";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0, shrink-to-fit=no" name="viewport" />
    <title>@ViewData["Title"] — Bulut ERP Entegrasyon</title>
    <link rel="icon" href="/thema/assets/img/kaiadmin/favicon.ico" type="image/x-icon" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/thema/assets/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/thema/assets/css/plugins.min.css" />
    <link rel="stylesheet" href="/thema/assets/css/kaiadmin.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.dataTables.min.css" />

    <style>
        * {
            font-family: 'Inter', sans-serif !important;
        }

        .logo {
            display: flex !important;
            align-items: center !important;
            gap: 8px !important;
            text-decoration: none !important;
        }

        .brand-name {
            color: #fff;
            font-size: 0.95rem;
            font-weight: 700;
            line-height: 1.1;
            display: block;
        }

        .brand-sub {
            color: rgba(255,255,255,.45);
            font-size: 0.65rem;
            font-weight: 500;
            letter-spacing: 1px;
            text-transform: uppercase;
            display: block;
        }

        .nav.nav-secondary .nav-item a {
            font-size: 0.875rem;
            font-weight: 500;
        }

            .nav.nav-secondary .nav-item a p {
                font-size: 0.875rem;
            }

        .nav-item a svg {
            margin-right: 8px;
            flex-shrink: 0;
        }

        .profile-username span {
            font-size: 0.85rem !important;
            font-weight: 600 !important;
        }

        .page-inner h3 {
            font-size: 1.3rem;
            font-weight: 700;
            color: #1a1a2e;
        }

        .card {
            border-radius: 12px;
            border: 1px solid #f0f0f0;
            box-shadow: 0 2px 12px rgba(0,0,0,.06);
        }

        .card-header {
            border-radius: 12px 12px 0 0 !important;
            padding: 1rem 1.25rem;
            border-bottom: 1px solid #f5f5f5;
            background: #fff;
        }

        .card-title {
            font-size: 0.95rem;
            font-weight: 600;
            color: #333;
            margin: 0;
        }

        .table {
            font-size: 0.82rem;
        }

            .table thead th {
                font-size: 0.78rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: .4px;
                color: #666;
                background: #f8f9fa;
            }

        .form-label {
            font-size: 0.8rem;
            font-weight: 600;
            color: #555;
            margin-bottom: 4px;
        }

        .form-control, .form-select {
            font-size: 0.85rem;
            border-radius: 8px;
            border-color: #e0e0e0;
        }

            .form-control:focus, .form-select:focus {
                border-color: #1a73e8;
                box-shadow: 0 0 0 3px rgba(26,115,232,.12);
            }

        .btn {
            font-size: 0.82rem;
            font-weight: 500;
            border-radius: 8px;
        }

        .btn-primary {
            background: #1a1a2e;
            border-color: #1a1a2e;
        }

            .btn-primary:hover {
                background: #16213e;
                border-color: #16213e;
            }

        .badge {
            font-size: 0.72rem;
            font-weight: 600;
            border-radius: 6px;
            padding: 3px 8px;
        }

        .footer {
            font-size: 0.8rem;
            color: #999;
            border-top: 1px solid #f0f0f0;
        }

        .dropdown-user .user-box h4 {
            font-size: 0.9rem;
            font-weight: 600;
        }

        .dropdown-item {
            font-size: 0.85rem;
        }

        .dataTables_wrapper .dataTables_filter input {
            font-size: 0.85rem;
            border-radius: 8px;
            border: 1px solid #e0e0e0;
            padding: 4px 10px;
        }

        .dataTables_wrapper .dataTables_length select {
            font-size: 0.85rem;
            border-radius: 8px;
            border: 1px solid #e0e0e0;
            padding: 3px 8px;
        }

        .dataTables_wrapper .dataTables_info,
        .dataTables_wrapper .dataTables_paginate {
            font-size: 0.8rem;
        }
        .dataTables_wrapper .paginate_button {
            border-radius: 6px !important;
            font-size: 0.8rem !important;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="wrapper">
        <!-- Sidebar -->
        <div class="sidebar" data-background-color="dark">
            <div class="sidebar-logo">
                <div class="logo-header" data-background-color="dark">
                    <a href="@Url.Action("Index", "Dashboard")" class="logo">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#4fc3f7" style="flex-shrink:0;">
                            <path d="M19.35 10.04A7.49 7.49 0 0 0 12 4C9.11 4 6.6 5.64 5.35 8.04A5.994 5.994 0 0 0 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z" />
                        </svg>
                        <div>
                            <span class="brand-name">Bulut ERP Entegrasyon</span>
                        </div>
                    </a>
                </div>
            </div>
            <hr style="height: 1px; background-color: white; border: none;">
            <div class="sidebar-wrapper scrollbar scrollbar-inner">
                <div class="sidebar-content">
                    <ul class="nav nav-secondary">
                        <li class="nav-section">
                            <span class="sidebar-mini-icon"><i class="fa fa-ellipsis-h"></i></span>
                            <h4 class="text-section">Menü</h4>
                        </li>
                        <li class="nav-item @(ViewData["ActiveMenu"]?.ToString() == "Dashboard" ? "active" : "")">
                            <a href="@Url.Action("Index", "Dashboard")">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" />
                                </svg>
                                <p>Dashboard</p>
                            </a>
                        </li>
                        <li class="nav-item @(ViewData["ActiveMenu"]?.ToString() == "SalesInvoice" ? "active" : "")">
                            <a href="@Url.Action("Index", "SalesInvoice")">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM8 13h8v1.5H8V13zm0 3h5v1.5H8V16zm0-6h3v1.5H8V10z" />
                                </svg>
                                <p>Satış Faturaları</p>
                            </a>
                        </li>

                        <li class="nav-item @(ViewData["ActiveMenu"]?.ToString() == "Ambar" ? "active" : "")">
                            <a href="@Url.Action("Index", "Ambar")">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M20 6h-2.18c.07-.44.18-.86.18-1.3C18 2.99 16.01 1 13.5 1c-1.4 0-2.59.68-3.37 1.72L9 4 7.87 2.72C7.09 1.68 5.9 1 4.5 1 1.99 1 0 2.99 0 5.5c0 .44.11.86.18 1.3H0v13c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8l-2-2zm-7-3c.83 0 1.5.67 1.5 1.5S13.83 6 13 6H10.5l1.13-1.47C12 4.2 12.47 3 13 3zM4.5 3C5.33 3 6 3.67 6 4.5S5.33 6 4.5 6c-.83 0-1.5-.67-1.5-1.5S3.67 3 4.5 3zM18 19H2V8h16v11z" />
                                </svg>
                                <p>Ambar Yönetimi</p>
                            </a>
                        </li>
                        <li class="nav-item @(ViewData["ActiveMenu"]?.ToString() == "CariFiltere" ? "active" : "")">
                            <a href="@Url.Action("Index", "CariFiltere")">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11H7v-2h10v2z" />
                                </svg>
                                <p>Kara Liste</p>
                            </a>
                        </li>
                        <li class="nav-item @(ViewData["ActiveMenu"]?.ToString() == "LotTakip" ? "active" : "")">
                            <a href="@Url.Action("Index", "LotTakip")">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm-5 14H4v-2h11v2zm5 0h-3v-2h3v2zm0-4H4v-2h16v2zm0-4H4V8h16v2z" />
                                </svg>
                                <p>Seri No Takip</p>
                            </a>
                        </li>
                        <li class="nav-item @(ViewData["ActiveMenu"]?.ToString() == "ApiLog" ? "active" : "")">
                            <a href="@Url.Action("Index", "ApiLog")">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M3 18h12v-2H3v2zm0-5h12v-2H3v2zm0-7v2h12V6H3zm14 9.67V7h-2v11.67l-1.5-1.5L12.09 18.5 16 22.41 19.91 18.5l-1.41-1.41L17 18.67zM3 6h12V4H3v2z" />
                                </svg>
                                <p>Hata Logları</p>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <!-- End Sidebar -->
        <div class="main-panel">
            <!-- Navbar -->
            <div class="main-header">
                <div class="main-header-logo">
                    <div class="logo-header" data-background-color="dark">
                        <a href="@Url.Action("Index", "Dashboard")" class="logo">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#4fc3f7">
                                <path d="M19.35 10.04A7.49 7.49 0 0 0 12 4C9.11 4 6.6 5.64 5.35 8.04A5.994 5.994 0 0 0 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z" />
                            </svg>
                            <span class="brand-name">Bulut ERP</span>
                        </a>
                        <div class="nav-toggle">
                            <button class="btn btn-toggle toggle-sidebar"><i class="gg-menu-right"></i></button>
                            <button class="btn btn-toggle sidenav-toggler"><i class="gg-menu-left"></i></button>
                        </div>
                        <button class="topbar-toggler more"><i class="gg-more-vertical-alt"></i></button>
                    </div>
                </div>
                <nav class="navbar navbar-header navbar-header-transparent navbar-expand-lg border-bottom">
                    <div class="container-fluid">
                        <ul class="navbar-nav topbar-nav ms-md-auto align-items-center">
                            <li class="nav-item topbar-user dropdown hidden-caret">
                                <a class="dropdown-toggle profile-pic" data-bs-toggle="dropdown" href="#" aria-expanded="false">
                                    <div class="avatar-sm">
                                        <span class="avatar-title rounded-circle bg-primary text-white fw-bold">
                                            @(username.Length > 0 ? username[0].ToString().ToUpper() : "U")
                                        </span>
                                    </div>
                                    <span class="profile-username ms-2">
                                        <span class="op-7 me-1" style="font-size:.8rem;">Merhaba,</span>
                                        <span class="fw-bold">@(username.Length > 20 ? username[..20] + "..." : username)</span>
                                    </span>
                                </a>
                                <ul class="dropdown-menu dropdown-user animated fadeIn">
                                    <li>
                                        <div class="dropdown-user-scroll scrollbar-outer">
                                            <div class="user-box">
                                                <div class="u-text">
                                                    <h4>@username</h4>
                                                    <small class="text-muted">Logo ERP Kullanıcısı</small>
                                                </div>
                                            </div>
                                            <div class="dropdown-divider"></div>
                                            <form asp-action="Logout" asp-controller="Auth" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item text-danger">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="margin-right:6px;">
                                                        <path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" />
                                                    </svg>
                                                    Çıkış Yap
                                                </button>
                                            </form>
                                        </div>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    </div>
                </nav>
            </div>
            <!-- End Navbar -->
            <!-- Content -->
            <div class="container">
                <div class="page-inner">
                    <div class="page-header pt-2 pb-3">
                        <h3 class="fw-bold mb-0">@ViewData["Title"]</h3>
                    </div>
                    @RenderBody()
                </div>
            </div>
            <!-- End Content -->
            <footer class="footer">
                <div class="container-fluid d-flex justify-content-between align-items-center">
                    <div class="copyright">
                        &copy; @DateTime.Now.Year <strong>Bulut ERP Entegrasyon</strong>
                    </div>
                    <div class="text-muted" style="font-size:.75rem;">
                        Geliştiren: <a href="https://mutluyazilim.com.tr/" target="_blank"
                                       style="color:#1a73e8;font-weight:600;text-decoration:none;">
                            Mutlu Yazılım
                        </a>
                    </div>
                </div>
            </footer>
        </div>
        <!-- End Main Panel -->
    </div>
    <!-- End Wrapper -->
    <script src="/thema/assets/js/core/jquery-3.7.1.min.js"></script>
    <script src="/thema/assets/js/core/popper.min.js"></script>
    <script src="/thema/assets/js/core/bootstrap.min.js"></script>
    <script src="/thema/assets/js/plugin/jquery-scrollbar/jquery.scrollbar.min.js"></script>
    <script src="/thema/assets/js/kaiadmin.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>