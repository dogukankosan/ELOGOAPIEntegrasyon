@model EBelgeUI.Models.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Giriş Yap";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0, shrink-to-fit=no" name="viewport" />
    <title>Bulut ERP Entegrasyon — Giriş</title>
    <link rel="icon" href="/thema/assets/img/kaiadmin/favicon.ico" type="image/x-icon" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/thema/assets/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/thema/assets/css/plugins.min.css" />
    <link rel="stylesheet" href="/thema/assets/css/kaiadmin.min.css" />
    <style>
        * {
            font-family: 'Inter', sans-serif !important;
        }

        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #0f1923;
            position: relative;
            overflow: hidden;
        }

            body::before {
                content: '';
                position: fixed;
                top: -200px;
                left: -200px;
                width: 600px;
                height: 600px;
                background: radial-gradient(circle, rgba(79,195,247,.15) 0%, transparent 70%);
                border-radius: 50%;
                animation: float1 8s ease-in-out infinite;
            }

            body::after {
                content: '';
                position: fixed;
                bottom: -150px;
                right: -150px;
                width: 500px;
                height: 500px;
                background: radial-gradient(circle, rgba(26,115,232,.15) 0%, transparent 70%);
                border-radius: 50%;
                animation: float2 10s ease-in-out infinite;
            }

        @@keyframes float1 {
            0%, 100% {
                transform: translate(0,0)
            }

            50% {
                transform: translate(40px,40px)
            }
        }

        @@keyframes float2 {
            0%, 100% {
                transform: translate(0,0)
            }

            50% {
                transform: translate(-30px,-30px)
            }
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(24px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        .login-wrapper {
            width: 100%;
            max-width: 440px;
            padding: 1.5rem;
            position: relative;
            z-index: 10;
            animation: slideUp .5s ease both;
        }

        .login-card {
            border-radius: 20px;
            border: 1px solid rgba(255,255,255,.08);
            background: rgba(255,255,255,.04);
            backdrop-filter: blur(20px);
            box-shadow: 0 25px 60px rgba(0,0,0,.4);
            overflow: hidden;
        }

        .login-header {
            background: linear-gradient(135deg,#1a73e8 0%,#0d47a1 100%);
            padding: 2.2rem 2rem;
            text-align: center;
            position: relative;
        }

            .login-header::after {
                content: '';
                position: absolute;
                bottom: -1px;
                left: 0;
                right: 0;
                height: 3px;
                background: linear-gradient(90deg,#4fc3f7,#1a73e8,#4fc3f7);
            }

        .header-icon {
            width: 60px;
            height: 60px;
            background: rgba(255,255,255,.15);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            backdrop-filter: blur(10px);
        }

        .brand-title {
            color: #fff;
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: -.5px;
            margin: 0 0 4px;
        }

        .brand-subtitle {
            color: rgba(255,255,255,.65);
            font-size: 0.75rem;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            margin: 0;
        }

        .login-body {
            padding: 2rem;
            background: #fff;
        }

        .welcome-title {
            font-size: 1.05rem;
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 4px;
        }

        .welcome-sub {
            font-size: 0.82rem;
            color: #999;
            margin-bottom: 1.5rem;
        }

        .form-label {
            font-size: 0.8rem;
            font-weight: 600;
            color: #444;
            margin-bottom: 5px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .form-control {
            font-size: 0.88rem;
            border-radius: 10px;
            border: 1.5px solid #e8e8e8;
            padding: 0.65rem 1rem;
            transition: all .2s;
            color: #333;
        }

            .form-control:focus {
                border-color: #1a73e8;
                box-shadow: 0 0 0 3px rgba(26,115,232,.12);
                outline: none;
            }

            .form-control::placeholder {
                color: #bbb;
            }

        .input-group .form-control {
            border-radius: 10px 0 0 10px !important;
        }

        .input-group-text {
            border-radius: 0 10px 10px 0 !important;
            border: 1.5px solid #e8e8e8;
            border-left: none;
            background: #f8f9fa;
            cursor: pointer;
            color: #888;
            transition: all .2s;
            padding: 0 14px;
            display: flex;
            align-items: center;
        }

            .input-group-text:hover {
                background: #f0f0f0;
                color: #1a73e8;
            }

        .btn-login {
            width: 100%;
            padding: 0.75rem;
            background: linear-gradient(135deg,#1a73e8 0%,#0d47a1 100%);
            border: none;
            border-radius: 10px;
            color: #fff;
            font-size: 0.9rem;
            font-weight: 600;
            letter-spacing: .3px;
            cursor: pointer;
            transition: all .2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(26,115,232,.4);
                color: #fff;
            }

            .btn-login:active {
                transform: translateY(0);
            }

            .btn-login:disabled {
                opacity: .7;
                transform: none;
                cursor: not-allowed;
            }

        .divider {
            display: flex;
            align-items: center;
            margin: 1.25rem 0;
            gap: 10px;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: #f0f0f0;
            }

            .divider span {
                font-size: 0.75rem;
                color: #ccc;
                white-space: nowrap;
            }

        .info-box {
            background: #f0f7ff;
            border: 1px solid #d0e8ff;
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 0.78rem;
            color: #555;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .footer-text {
            text-align: center;
            font-size: 0.75rem;
            color: #bbb;
            margin-top: 1.25rem;
        }
        .alert-danger {
            border-radius: 10px;
            border: 1px solid #ffd0d0;
            background: #fff5f5;
            color: #c0392b;
            font-size: 0.83rem;
            padding: 10px 14px;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-card">
            <!-- Header -->
            <div class="login-header">
                <div class="header-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="white">
                        <path d="M19.35 10.04A7.49 7.49 0 0 0 12 4C9.11 4 6.6 5.64 5.35 8.04A5.994 5.994 0 0 0 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z" />
                    </svg>
                </div>
                <h1 class="brand-title">Bulut ERP</h1>
                <p class="brand-subtitle">Entegrasyon Sistemi</p>
            </div>
            <!-- Body -->
            <div class="login-body">
                <p class="welcome-title">Hoş Geldiniz 👋</p>
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger d-flex align-items-center mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#c0392b" class="me-2" style="flex-shrink:0">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                        </svg>
                        <div>@Model.ErrorMessage</div>
                    </div>
                }
                <form id="loginForm" method="post" asp-action="Login" asp-controller="Auth">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="Username" class="form-label">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#1a73e8">
                                <path d="M12 12c2.7 0 5-2.3 5-5s-2.3-5-5-5-5 2.3-5 5 2.3 5 5 5zm0 2c-3.3 0-10 1.7-10 5v2h20v-2c0-3.3-6.7-5-10-5z" />
                            </svg>
                            Kullanıcı Adı
                        </label>
                        <input type="text" class="form-control" id="Username" name="Username"
                               value="@Model.Username" placeholder="ornek@sirket.com" autofocus />
                    </div>
                    <div class="mb-4">
                        <label for="Password" class="form-label">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#1a73e8">
                                <path d="M18 8h-1V6c0-2.8-2.2-5-5-5S7 3.2 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.7 1.4-3.1 3.1-3.1 1.7 0 3.1 1.4 3.1 3.1v2z" />
                            </svg>
                            Şifre
                        </label>
                        <div class="input-group">
                            <input type="password" class="form-control" id="Password"
                                   name="Password" placeholder="············" />
                            <span class="input-group-text" id="togglePassword" title="Şifreyi göster/gizle">
                                <!-- Göz ikonu -->
                                <svg id="iconEyeOff" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 7c2.8 0 5 2.2 5 5 0 .6-.1 1.2-.4 1.8l2.9 2.9c1.5-1.3 2.7-3 3.4-4.7C21.3 7.6 17 4.9 12 4.9c-1.4 0-2.7.2-3.9.7L10.2 7.6c.6-.4 1.2-.6 1.8-.6zM2 4.3l2.3 2.3.5.5C3.1 8.4 1.8 10.2 1 12.2c1.7 4.3 6 7.3 11 7.3 1.5 0 3-.3 4.4-.8l.4.4 2.9 2.9 1.3-1.3L3.3 3 2 4.3zm5.5 5.5l1.6 1.6c0 .2-.1.4-.1.6 0 1.7 1.3 3 3 3 .2 0 .4 0 .6-.1l1.6 1.6c-.6.3-1.4.5-2.2.5-2.8 0-5-2.2-5-5 0-.8.2-1.5.5-2.2z" />
                                </svg>
                                <svg id="iconEyeOn" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="display:none;">
                                    <path d="M12 4.5C7 4.5 2.7 7.6 1 12c1.7 4.4 6 7.5 11 7.5s9.3-3.1 11-7.5C21.3 7.6 17 4.5 12 4.5zm0 12.5c-2.8 0-5-2.2-5-5s2.2-5 5-5 5 2.2 5 5-2.2 5-5 5zm0-8c-1.7 0-3 1.3-3 3s1.3 3 3 3 3-1.3 3-3-1.3-3-3-3z" />
                                </svg>
                            </span>
                        </div>
                    </div>
                    <div class="mb-3 d-flex align-items-center gap-2">
                        <input type="checkbox" class="form-check-input" id="RememberMe" name="RememberMe" value="true" style="width:18px;height:18px;cursor:pointer;" />
                        <label for="RememberMe" class="form-label mb-0" style="cursor:pointer;">Beni hatırla (1 hafta)</label>
                    </div>
                    <button type="submit" class="btn-login" id="loginBtn">
                        <span id="btnText" style="display:flex; align-items:center; gap:8px;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="white">
                                <path d="M11 7L9.6 8.4l2.6 2.6H2v2h10.2l-2.6 2.6L11 17l5-5-5-5zm9 12h-8v2h8c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-8v2h8v14z" />
                            </svg>
                            Giriş Yap
                        </span>
                        <span id="btnSpinner" style="display:none; align-items:center; gap:8px;">
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                            Giriş yapılıyor...
                        </span>
                    </button>
                </form>
                <div class="info-box">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#1a73e8" style="flex-shrink:0;">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" />
                    </svg>
                    <span>Logo ERP kullanıcı adı ve şifrenizle giriş yapabilirsiniz.</span>
                </div>
                <p class="footer-text">
                    &copy; @DateTime.Now.Year Bulut ERP Entegrasyon &nbsp;|&nbsp;
                    <a href="https://mutluyazilim.com.tr/" target="_blank"
                       style="color:#1a73e8;font-weight:600;text-decoration:none;">
                        Mutlu Yazılım
                    </a>
                </p>
            </div>
        </div>
    </div>
    <script src="/thema/assets/js/core/jquery-3.7.1.min.js"></script>
    <script src="/thema/assets/js/core/popper.min.js"></script>
    <script src="/thema/assets/js/core/bootstrap.min.js"></script>
    <script>
        document.getElementById('loginForm').addEventListener('submit', function () {
            document.getElementById('loginBtn').disabled        = true;
            document.getElementById('btnText').style.display    = 'none';
            document.getElementById('btnSpinner').style.display = 'flex';
        });
        document.getElementById('togglePassword').addEventListener('click', function () {
            const pwd    = document.getElementById('Password');
            const eyeOff = document.getElementById('iconEyeOff');
            const eyeOn  = document.getElementById('iconEyeOn');
            if (pwd.type === 'password') {
                pwd.type             = 'text';
                eyeOff.style.display = 'none';
                eyeOn.style.display  = 'block';
            } else {
                pwd.type             = 'password';
                eyeOff.style.display = 'block';
                eyeOn.style.display  = 'none';
            }
        });
    </script>
</body>
</html>