@model EBelgeUI.Models.CariFiltereIndexViewModel
@{
    ViewData["Title"] = "Cari Filtre (Kara Liste)";
    ViewData["ActiveMenu"] = "CariFiltere";
}

<style>
    .filtre-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        border: 1px solid #e0e0e0;
    }

        .filtre-card .card-header {
            background: linear-gradient(135deg, #b71c1c, #c62828);
            border-radius: 12px 12px 0 0;
            padding: 14px 20px;
        }

    .badge-aktif {
        background: #e6f4ea;
        color: #188038;
        font-size: 0.72rem;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 600;
    }

    .badge-pasif {
        background: #f5f5f5;
        color: #888;
        font-size: 0.72rem;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 600;
    }

    .badge-vkn {
        background: #e3f2fd;
        color: #1565c0;
        font-size: 0.72rem;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 600;
    }

    .badge-tckn {
        background: #f3e5f5;
        color: #6a1b9a;
        font-size: 0.72rem;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 600;
    }

    .btn-action {
        width: 30px;
        height: 30px;
        border-radius: 7px;
        border: 1.5px solid;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .15s;
        background: transparent;
        padding: 0;
        font-size: 0.8rem;
    }

    .btn-delete {
        border-color: #c62828;
        color: #c62828;
    }

        .btn-delete:hover {
            background: #c62828;
            color: white;
        }

    .btn-toggle {
        border-color: #888;
        color: #888;
    }

        .btn-toggle:hover {
            background: #888;
            color: white;
        }

    .form-control, .form-select {
        border: 1.5px solid #e0e0e0;
        border-radius: 8px;
        font-size: 0.85rem;
    }

        .form-control:focus, .form-select:focus {
            border-color: #c62828;
            box-shadow: 0 0 0 3px rgba(198,40,40,0.12);
        }

    table thead th {
        font-size: 0.73rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .4px;
        color: #555;
        background: #f8f9fa;
        border-bottom: 2px solid #e9ecef;
        padding: 10px 14px;
    }

    table tbody td {
        font-size: 0.83rem;
        vertical-align: middle;
        padding: 9px 14px;
    }

    table tbody tr:hover td {
        background: #fff5f5;
    }

    table tbody tr.pasif-row td {
        opacity: 0.5;
    }

    .info-box {
        background: #fff5f5;
        border: 1px solid #ffcdd2;
        border-radius: 10px;
        padding: 12px 16px;
        font-size: 0.78rem;
        color: #b71c1c;
    }

    .kimlik-code {
        font-family: monospace;
        font-size: 0.85rem;
        background: #f5f5f5;
        padding: 2px 8px;
        border-radius: 4px;
        font-weight: 600;
    }
</style>

<div class="row g-3">
    <!-- SOL: FORM -->
    <div class="col-md-4">
        <div class="filtre-card mb-3">
            <div class="card-header d-flex align-items-center gap-2">
                <span>🚫</span>
                <h5 class="mb-0 text-white" style="font-size:0.9rem;font-weight:700;">
                    Kara Listeye Ekle
                </h5>
            </div>
            <div class="card-body p-3">
                <div class="mb-3">
                    <label class="form-label" style="font-size:0.78rem;font-weight:600;">
                        Kimlik Tipi <span class="text-danger">*</span>
                    </label>
                    <select id="kimlikTipi" class="form-select form-select-sm">
                        <option value="VKN">VKN (Vergi Kimlik No)</option>
                        <option value="TCKN">TCKN (TC Kimlik No)</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label" style="font-size:0.78rem;font-weight:600;">
                        Kimlik No <span class="text-danger">*</span>
                    </label>
                    <input type="text" id="kimlikNo" class="form-control form-control-sm"
                           placeholder="VKN veya TCKN..." maxlength="11"
                           oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                </div>
                <div class="mb-3">
                    <label class="form-label" style="font-size:0.78rem;font-weight:600;">Ad / Ünvan</label>
                    <input type="text" id="kimlikAd" class="form-control form-control-sm"
                           placeholder="Firma veya kişi adı..." maxlength="200" />
                </div>
                <div class="mb-3">
                    <label class="form-label" style="font-size:0.78rem;font-weight:600;">Açıklama</label>
                    <textarea id="kimlikAciklama" class="form-control form-control-sm"
                              placeholder="Neden engellendi?" rows="2" maxlength="500"></textarea>
                </div>
                <button class="btn btn-danger btn-sm w-100" onclick="saveFiltre()"
                        style="font-size:0.82rem;">
                    🚫 Kara Listeye Ekle
                </button>
            </div>
        </div>

        <div class="info-box">
            <strong>⚠️ Dikkat:</strong><br>
            Kara listedeki VKN veya TCKN'ye sahip müşterilerin faturaları
            <strong>e-Logo'dan hiç çekilmez</strong> ve listede görünmez.
        </div>
    </div>

    <!-- SAĞ: LİSTE -->
    <div class="col-md-8">
        <div class="filtre-card">
            <div class="card-header d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-2">
                    <span>📋</span>
                    <h5 class="mb-0 text-white" style="font-size:0.9rem;font-weight:700;">
                        Kara Liste
                    </h5>
                    <span style="background:rgba(255,255,255,0.2);color:white;font-size:0.7rem;padding:2px 10px;border-radius:20px;font-weight:700;">
                        @Model.Filtreler.Count kayıt
                    </span>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-light filter-btn" onclick="filterFiltre('all')" id="filter-all" style="font-size:0.75rem;">Tümü</button>
                    <button class="btn btn-sm btn-outline-light filter-btn" onclick="filterFiltre('aktif')" id="filter-aktif" style="font-size:0.75rem;">Aktif</button>
                    <button class="btn btn-sm btn-outline-light filter-btn" onclick="filterFiltre('pasif')" id="filter-pasif" style="font-size:0.75rem;">Pasif</button>
                </div>
            </div>
            <div class="card-body p-0">
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger m-3">⚠️ @Model.ErrorMessage</div>
                }
                else if (!Model.Filtreler.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <div style="font-size:2.5rem;">🚫</div>
                        <p class="mt-2" style="font-size:.85rem;">Kara listede kayıt yok.</p>
                    </div>
                }
                else
                {
                    <table class="table table-hover mb-0" id="filtreTable">
                        <thead>
                            <tr>
                                <th>Tip</th>
                                <th>Kimlik No</th>
                                <th>Ad / Ünvan</th>
                                <th>Açıklama</th>
                                <th>Durum</th>
                                <th>Eklenme</th>
                                <th class="text-center">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var f in Model.Filtreler)
                            {
                                <tr data-id="@f.Id" data-aktif="@f.IsActive.ToString().ToLower()"
                                    class="@(!f.IsActive ? "pasif-row" : "")">
                                    <td>
                                        <span class="@(f.KimlikTipi == "VKN" ? "badge-vkn" : "badge-tckn")">
                                            @f.KimlikTipi
                                        </span>
                                    </td>
                                    <td>
                                        <span class="kimlik-code">@f.KimlikNo</span>
                                    </td>
                                    <td>
                                        <small style="font-weight:600;">@f.Ad</small>
                                    </td>
                                    <td>
                                        <small class="text-muted" style="font-size:0.75rem;">
                                            @(f.Aciklama?.Length > 40
                                                                                ? f.Aciklama[..40] + "..."
                                                                                : f.Aciklama)
                                </small>
                            </td>
                            <td>
                                @if (f.IsActive)
                                        {
                                            <span class="badge-aktif">✓ Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="badge-pasif">✗ Pasif</span>
                                        }
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            @f.CreatedAt.ToString("dd.MM.yyyy")
                                        </small>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex gap-1 justify-content-center">
                                            <button class="btn-action btn-toggle"
                                                    title="@(f.IsActive ? "Pasife Al" : "Aktife Al")"
                                                    onclick="toggleActive(@f.Id, @f.IsActive.ToString().ToLower())">
                                                @(f.IsActive ? "⏸" : "▶")
                                            </button>
                                            <button class="btn-action btn-delete" title="Sil"
                                                    onclick="deleteFiltre(@f.Id, '@f.KimlikNo')">
                                                🗑
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
              function saveFiltre() {
            var kimlikTipi = document.getElementById('kimlikTipi').value;
            var kimlikNo = document.getElementById('kimlikNo').value.trim();
            var ad = document.getElementById('kimlikAd').value.trim();
            var aciklama = document.getElementById('kimlikAciklama').value.trim();

            // ── Zorunlu kontrol ──
            if (!kimlikNo) {
                Swal.fire('Uyarı', 'Kimlik No zorunludur.', 'warning'); return;
            }

            // ── Sadece rakam kontrolü ──
            if (!/^\d+$/.test(kimlikNo)) {
                Swal.fire('Uyarı', 'Kimlik No sadece rakam içermelidir.', 'warning'); return;
            }

            // ── İlk hane 0 olamaz ──
            if (kimlikNo[0] === '0') {
                Swal.fire('Uyarı', kimlikTipi + ' 0 ile başlayamaz.', 'warning'); return;
            }

            // ── Hane sayısı kontrolü ──
            if (kimlikTipi === 'VKN' && kimlikNo.length !== 10) {
                Swal.fire('Uyarı', 'VKN 10 haneli olmalıdır. (Girilen: ' + kimlikNo.length + ' hane)', 'warning'); return;
            }
            if (kimlikTipi === 'TCKN' && kimlikNo.length !== 11) {
                Swal.fire('Uyarı', 'TCKN 11 haneli olmalıdır. (Girilen: ' + kimlikNo.length + ' hane)', 'warning'); return;
            }

            Swal.fire({ title: 'Ekleniyor...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });

            fetch('/CariFiltere/Create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ kimlikNo, kimlikTipi, ad, aciklama, isActive: true })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({ title: 'Eklendi', icon: 'success', timer: 1500, showConfirmButton: false })
                        .then(() => location.reload());
                } else {
                    Swal.fire('Hata', data.message || 'Eklenemedi.', 'error');
                }
            })
            .catch(() => Swal.fire('Hata', 'Bağlantı hatası.', 'error'));
        }

        function deleteFiltre(id, kimlikNo) {
            Swal.fire({
                title: 'Kara Listeden Çıkar',
                html: '<b>' + kimlikNo + '</b> kara listeden çıkarılacak.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#c62828',
                cancelButtonColor: '#757575',
                confirmButtonText: '🗑 Evet, Sil',
                cancelButtonText: 'İptal',
                reverseButtons: true
            }).then(function(result) {
                if (!result.isConfirmed) return;

                fetch('/CariFiltere/Delete/' + id, { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        document.querySelector('tr[data-id="' + id + '"]')?.remove();
                        Swal.fire({ title: 'Silindi', icon: 'success', timer: 1200, showConfirmButton: false });
                    } else {
                        Swal.fire('Hata', data.message || 'Silinemedi.', 'error');
                    }
                })
                .catch(() => Swal.fire('Hata', 'Bağlantı hatası.', 'error'));
            });
        }

        function toggleActive(id, isActive) {
            var yeniDurum = !isActive;
            Swal.fire({
                title: 'Durum Değiştir',
                text: yeniDurum ? 'Filtre aktife alınacak.' : 'Filtre pasife alınacak.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#1a73e8',
                cancelButtonColor: '#757575',
                confirmButtonText: 'Evet',
                cancelButtonText: 'İptal',
                reverseButtons: true
            }).then(function(result) {
                if (!result.isConfirmed) return;

                fetch('/CariFiltere/SetActive/' + id + '?isActive=' + yeniDurum, { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire({ title: 'Güncellendi', icon: 'success', timer: 1200, showConfirmButton: false })
                            .then(() => location.reload());
                    } else {
                        Swal.fire('Hata', data.message || 'Güncellenemedi.', 'error');
                    }
                })
                .catch(() => Swal.fire('Hata', 'Bağlantı hatası.', 'error'));
            });
        }

        function filterFiltre(type) {
            document.querySelectorAll('tr[data-id]').forEach(function(row) {
                var aktif = row.getAttribute('data-aktif') === 'true';
                if (type === 'all') row.style.display = '';
                else if (type === 'aktif') row.style.display = aktif ? '' : 'none';
                else if (type === 'pasif') row.style.display = !aktif ? '' : 'none';
            });
        }
    </script>
}