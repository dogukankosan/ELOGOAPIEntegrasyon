@{
    Layout = Context.Session.GetString("Token") != null ? "_Layout" : null;
    var code = (int)(ViewBag.StatusCode ?? 0);
    var is404 = code == 404;
    ViewData["Title"] = is404 ? "Sayfa Bulunamadı" : "Hata";
}
<link rel="icon" href="/thema/assets/img/kaiadmin/favicon.ico" type="image/x-icon" />
<style>
    .error-box {
        background: white;
        border-radius: 20px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.12);
        padding: 60px 50px;
        text-align: center;
        max-width: 500px;
        width: 100%;
        border-top: 5px solid @(is404 ? "#1a73e8" : "#c62828");
        margin: 60px auto;
    }
    .error-code {
        font-size: 5rem;
        font-weight: 900;
        color: #f0f0f0;
        font-family: monospace;
        line-height: 1;
    }
    .error-title {
        font-size: 1.4rem;
        font-weight: 800;
        color: @(is404 ? "#1a73e8" : "#c62828");
        margin: 10px 0;
    }
    .error-desc {
        color: #888;
        font-size: 0.88rem;
        line-height: 1.7;
        margin-bottom: 30px;
    }
    .btn-home {
        background: linear-gradient(135deg,#1a73e8,#0d47a1);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 10px 28px;
        font-size: 0.88rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all .2s;
        box-shadow: 0 4px 14px rgba(26,115,232,0.3);
    }
        .btn-home:hover {
            transform: translateY(-2px);
            color: white;
        }
    .btn-back {
        background: transparent;
        color: #888;
        border: 1.5px solid #e0e0e0;
        border-radius: 10px;
        padding: 10px 20px;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all .2s;
    }
        .btn-back:hover {
            background: #f5f5f5;
            color: #555;
        }
</style>
<div class="error-box">
    <div class="error-code">@(code > 0 ? code.ToString() : "?")</div>
    @if (is404)
    {
        <h2 class="error-title">Sayfa Bulunamadı</h2>
        <p class="error-desc">Aradığınız sayfa taşınmış, silinmiş veya hiç var olmamış olabilir.</p>
    }
    else
    {
        <h2 class="error-title">Bir Hata Oluştu</h2>
        <p class="error-desc">Beklenmedik bir hata meydana geldi.<br>Sorun devam ederse sistem yöneticisi ile iletişime geçin.</p>
    }
    <div class="d-flex gap-3 justify-content-center">
        <button class="btn-back" onclick="history.back()">← Geri Dön</button>
        <a href="/" class="btn-home">🏠 Ana Sayfa</a>
    </div>
    <div class="mt-3">
        <small style="color:#ccc;font-size:0.7rem;">Hata Kodu: @code</small>
    </div>
</div>